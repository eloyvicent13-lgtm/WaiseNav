# Server
PORT=8164
NODE_ENV=production

# Public API base the app connects to (Pterodactyl allocation)
PUBLIC_API_HOST=149.202.84.78
PUBLIC_API_PORT=8164

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Database (SQLite file by default, swap to mysql:// or postgres:// if your
# Pterodactyl stack has a DB service — Prisma datasource stays the same shape)
DATABASE_URL="file:./data/waisenav.db"

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_WHISPER_MODEL=whisper-1

# Places search (Google Places Nearby Search). Swap provider in
# src/services/places.service.js if you prefer OSM/Overpass (no key needed).
GOOGLE_PLACES_API_KEY=your-google-places-key
